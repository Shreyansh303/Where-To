# --- API keys (required for live runs) ---
SERPAPI_API_KEY=your-serpapi-key            # SerpApi (Google Flights + Google Hotels)
GOOGLE_MAPS_API_KEY=your-google-maps-key    # Google Places API (New) + Routes API
GROQ_API_KEY=your-groq-key                  # LLM orchestration

# --- LLM ---
GROQ_MODEL=llama-3.3-70b-versatile

# --- Money ---
CURRENCY=INR                                # passed to SerpApi; all prices displayed in this currency

# --- Cache (seconds). Flights/hotels match SerpApi's own 1h cache window. ---
CACHE_PATH=where_to_cache.sqlite3
CACHE_TTL_FLIGHTS=3600
CACHE_TTL_HOTELS=3600
CACHE_TTL_PLACES=86400
CACHE_TTL_ROUTES=86400

# --- Dev/demo mode: fixture-backed clients + scripted LLM, zero API spend ---
FAKE_APIS=0

# --- API surface ---
CORS_ORIGINS=http://localhost:3000
